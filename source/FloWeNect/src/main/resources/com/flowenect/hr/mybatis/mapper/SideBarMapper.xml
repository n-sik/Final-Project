<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.flowenect.hr.sidebar.mapper.SideBarMapper">
	    <!-- ============================= -->
    <!-- 1. 전체 메뉴 조회 (개인 정렬 적용) -->
    <!-- ============================= -->
    <select id="selectMenuListByEmp"
            parameterType="string"
            resultType="com.flowenect.hr.dto.sidebar.MenuDTO">

        SELECT
            M.MENU_NO,
            M.PARENT_MENU_NO,
            M.MENU_NM,
            M.MENU_LVL,
            M.MENU_URL,
            NVL(E.SORT_ORD, M.SORT_ORD) AS SORT_ORD,
            M.USE_YN,
            M.MENU_TYPE
        FROM MENU_MASTER M
        LEFT JOIN EMP_MENU_SET E
            ON M.MENU_NO = E.MENU_NO
           AND E.EMP_NO = #{empNo}
        WHERE M.USE_YN = 'Y'
        ORDER BY M.MENU_LVL, SORT_ORD

    </select>


    <!-- ============================= -->
    <!-- 2. 기존 개인 정렬 삭제 -->
    <!-- ============================= -->
    <delete id="deleteEmpMenuSort"
            parameterType="string">

        DELETE FROM EMP_MENU_SET
        WHERE EMP_NO = #{empNo}

    </delete>


    <!-- ============================= -->
    <!-- 3. 개인 정렬 저장 -->
    <!-- ============================= -->
    <insert id="insertEmpMenuSort"
            parameterType="com.flowenect.hr.dto.sidebar.EmpMenuSetDTO">

        INSERT INTO EMP_MENU_SET (
            MENU_NO,
            EMP_NO,
            SORT_ORD
        ) VALUES (
            #{menuNo},
            #{empNo},
            #{sortOrd}
        )

    </insert>
	
</mapper>