<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
  PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.flowenect.hr.security.policy.mapper.SecurityPolicyMapper">

  <resultMap id="RoleHierarchyEdgeMap" type="RoleHierarchyEdgeDTO">
    <result property="parentRoleCd" column="PARENT_ROLE_CD"/>
    <result property="childRoleCd" column="CHILD_ROLE_CD"/>
  </resultMap>

  <select id="selectRoleHierarchyEdges" resultMap="RoleHierarchyEdgeMap">
    SELECT
      PARENT_ROLE_CD,
      CHILD_ROLE_CD
    FROM ROLE_HIERARCHY
    WHERE PARENT_ROLE_CD IS NOT NULL
      AND CHILD_ROLE_CD IS NOT NULL
    ORDER BY PARENT_ROLE_CD, CHILD_ROLE_CD
  </select>

  <select id="selectPolicyVer" parameterType="java.lang.String" resultType="int">
    SELECT NVL(VER_NO, 0)
    FROM SEC_POLICY_VER
    WHERE POLICY_KEY = #{policyKey}
  </select>

</mapper>