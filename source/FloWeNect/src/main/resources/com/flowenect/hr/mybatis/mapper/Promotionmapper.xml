<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
  "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.flowenect.hr.promotion.mapper.PromotionMapper">

    <!-- ================================================== -->
    <!-- 1. 승진 결재 목록 조회                                -->
    <!-- ================================================== -->
    <select id="selectPromotionList"
            parameterType="com.flowenect.hr.dto.promotion.PromotionDTO"
            resultType="com.flowenect.hr.dto.promotion.PromotionDTO">
        SELECT
              D.APRV_NO
            , D.SUBMIT_DTM
            , D.EMP_NO
            , D.DOC_WRTR_EMP_NM
            , D.DOC_WRTR_POS_CD
            , D.DOC_WRTR_EMP_NM || ' ' || D.DOC_WRTR_POS_CD AS DRAFTER
            , D.STAT_CD
            , D.FINAL_DTM
            , P.TARGET_EMP_NO
            , P.TARGET_POS_CD
            , P.EFFECTIVE_DTM
            , P.REASON
            , E.EMP_NM  AS TARGET_EMP_NM   -- 승진 대상 사원명
            , E.POS_CD  AS CURRENT_POS_CD   -- 현재 직위
        FROM APRV_DOC D
        JOIN APRV_PROMOTION P ON D.APRV_NO     = P.APRV_NO
        JOIN EMP E            ON P.TARGET_EMP_NO = E.EMP_NO
        <where>
            AND D.FORM_CD = 'PROMOTION'
            <if test="empNo != null and empNo != ''">
                AND D.EMP_NO = #{empNo}
            </if>
            <if test="statCd != null and statCd != ''">
                AND D.STAT_CD = #{statCd}
            </if>
            <if test="aprvNo != null and aprvNo != ''">
                AND D.APRV_NO = #{aprvNo}
            </if>
        </where>
        ORDER BY D.SUBMIT_DTM DESC
    </select>


    <!-- ================================================== -->
    <!-- 2. 단건 조회                                         -->
    <!-- ================================================== -->
    <select id="selectPromotionDetail"
            parameterType="string"
            resultType="com.flowenect.hr.dto.promotion.PromotionDTO">
        SELECT
              D.APRV_NO
            , D.SUBMIT_DTM
            , D.EMP_NO
            , D.DOC_WRTR_EMP_NM
            , D.DOC_WRTR_POS_CD
            , D.DOC_WRTR_EMP_NM || ' ' || D.DOC_WRTR_POS_CD AS DRAFTER
            , D.STAT_CD
            , D.FINAL_DTM
            , P.TARGET_EMP_NO
            , P.TARGET_POS_CD
            , P.EFFECTIVE_DTM
            , P.REASON
            , E.EMP_NM  AS TARGET_EMP_NM
            , E.POS_CD  AS CURRENT_POS_CD
        FROM APRV_DOC D
        JOIN APRV_PROMOTION P ON D.APRV_NO     = P.APRV_NO
        JOIN EMP E            ON P.TARGET_EMP_NO = E.EMP_NO
        WHERE D.APRV_NO = #{aprvNo}
    </select>


    <!-- ================================================== -->
    <!-- 3. 전체 건수                                         -->
    <!-- ================================================== -->
    <select id="selectPromotionCount"
            parameterType="com.flowenect.hr.dto.promotion.PromotionDTO"
            resultType="int">
        SELECT COUNT(*)
        FROM APRV_DOC D
        JOIN APRV_PROMOTION P ON D.APRV_NO = P.APRV_NO
        <where>
            AND D.FORM_CD = 'PROMOTION'
            <if test="empNo != null and empNo != ''">
                AND D.EMP_NO = #{empNo}
            </if>
            <if test="statCd != null and statCd != ''">
                AND D.STAT_CD = #{statCd}
            </if>
        </where>
    </select>


    <!-- ================================================== -->
    <!-- 4. [단건] APRV_DOC 결재 상태 업데이트                -->
    <!-- ================================================== -->
    <update id="updateAprvDocStatus"
            parameterType="com.flowenect.hr.dto.promotion.PromotionApproveDTO">
        UPDATE APRV_DOC
           SET STAT_CD   = #{statCd}
             , FINAL_DTM = SYSDATE
         WHERE APRV_NO   = #{aprvNo}
    </update>


    <!-- ================================================== -->
    <!-- 5. [다건] APRV_DOC 결재 상태 일괄 업데이트            -->
    <!-- ================================================== -->
    <update id="updateAprvDocStatusBulk"
            parameterType="com.flowenect.hr.dto.promotion.PromotionApproveDTO">
        UPDATE APRV_DOC
           SET STAT_CD   = #{statCd}
             , FINAL_DTM = SYSDATE
         WHERE APRV_NO IN
        <foreach collection="aprvNos" item="no" open="(" separator="," close=")">
            #{no}
        </foreach>
    </update>


    <!-- ================================================== -->
    <!-- 6. 승인 확정 시 EMP 직위 변경                         -->
    <!--    EMP.POS_CD = TARGET_POS_CD (승진 대상자 기준)      -->
    <!-- ================================================== -->
    <update id="updateEmpPos"
            parameterType="com.flowenect.hr.dto.promotion.PromotionDTO">
        UPDATE EMP
           SET POS_CD  = #{targetPosCd}
             , MOD_DTM = SYSDATE
         WHERE EMP_NO  = #{targetEmpNo}
    </update>


    <!-- ================================================== -->
    <!-- 7. 다건 승인 시 targetEmpNo + targetPosCd 일괄 조회   -->
    <!-- ================================================== -->
    <select id="selectPromotionDetailsByAprvNos"
            resultType="com.flowenect.hr.dto.promotion.PromotionDTO">
        SELECT D.APRV_NO
             , P.TARGET_EMP_NO
             , P.TARGET_POS_CD
        FROM APRV_DOC D
        JOIN APRV_PROMOTION P ON D.APRV_NO = P.APRV_NO
        WHERE D.APRV_NO IN
        <foreach collection="list" item="no" open="(" separator="," close=")">
            #{no}
        </foreach>
    </select>
    

</mapper>